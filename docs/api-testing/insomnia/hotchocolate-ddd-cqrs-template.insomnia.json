      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"query\": \"query ListProducts($pageNumber: Int!, $pageSize: Int!) { products(pageNumber: $pageNumber, pageSize: $pageSize) { totalCount pageNumber pageSize items { id name price currency sku isArchived category { id name slug } } } }\",\n  \"variables\": {\n    \"pageNumber\": 1,\n    \"pageSize\": 10\n  }\n}"
